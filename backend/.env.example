# Appwrite (only needed for auth/login; charts work without these)
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id
APPWRITE_API_KEY=your_server_api_key

# CORS — comma-separated frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Market data is keyless by default (Binance for crypto, Yahoo Finance for the
# rest). OPTIONAL: add a free TwelveData API key (https://twelvedata.com) to use
# it for forex + gold instead of Yahoo — more reliable. Leave blank to skip.
TWELVEDATA_API_KEY=

# AI Mentor (Phase 5) — OPTIONAL, provider-agnostic. Pick one and add its key.
# Groq and Gemini have free tiers; Anthropic is paid. Leave all blank to disable.
AI_PROVIDER=groq
GROQ_API_KEY=            # free: https://console.groq.com
GEMINI_API_KEY=         # free: https://aistudio.google.com/apikey
OPENAI_API_KEY=         # paid: https://platform.openai.com
ANTHROPIC_API_KEY=      # paid: https://console.anthropic.com
# Optional model override (blank = provider default, e.g. llama-3.3-70b-versatile)
MENTOR_MODEL=

# Notifications (Module 15) — OPTIONAL. Desktop alerts work in the browser with
# none of these. Set to also fan out scanner alerts to Discord / Telegram.
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=6cc5d77bc7f64d0d8d14c8c52972a4e3
